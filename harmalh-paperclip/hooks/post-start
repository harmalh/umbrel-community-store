#!/usr/bin/env bash
# Runs after every `compose up` (install, update, restart). Retries CEO bootstrap
# when the API is healthy — needed after fixing embedded-Postgres permissions without
# bumping app version.
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec "${SCRIPT_DIR}/paperclip-try-bootstrap-ceo"
