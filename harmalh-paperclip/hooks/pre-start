#!/bin/bash
set -Eeuo pipefail

# shellcheck source=/dev/null
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/paperclip-umbrel-env.sh"
_HOST_PORT="$(paperclip_published_host_port)"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PKG_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

mkdir -p "${APP_DATA_DIR}/data"
chown -R 1000:1000 "${APP_DATA_DIR}/data" || true
# Embedded PostgreSQL (Paperclip) only accepts data directories with mode 0700 or
# 0750 (u=rwx, g=rx, o=—). A recursive `chmod … g+rwX` breaks …/instances/*/db on
# every start and matches the "invalid permissions" FATAL in Postgres logs.
chmod u+rwx "${APP_DATA_DIR}/data" || true
find "${APP_DATA_DIR}/data" -type d -path '*/instances/*/db' -exec chmod 700 {} \; \
    2>/dev/null || true
# Explicit path: guarantees fix even if find -path behaves differently (busybox, odd layouts).
DB_DIR="${APP_DATA_DIR}/data/instances/default/db"
if [[ -d "${DB_DIR}" ]]; then
    chmod 700 "${DB_DIR}" || true
fi
# Tighten instance dirs so Postgres does not reject the cluster (avoid world-writable parents).
INST_ROOT="${APP_DATA_DIR}/data/instances"
if [[ -d "${INST_ROOT}" ]]; then
    chmod 750 "${INST_ROOT}" || true
    if [[ -d "${INST_ROOT}/default" ]]; then
        chmod 750 "${INST_ROOT}/default" || true
    fi
fi

# The Paperclip CLI (`paperclipai auth bootstrap-ceo`) requires an on-disk
# config.json even when the server runs from env (see paperclipai/paperclip#87).
# Seed a minimal Umbrel-aligned config before the first container start so
# post-install / post-update hooks can run bootstrap non-interactively.
CONFIG_DIR="${APP_DATA_DIR}/data/instances/default"
CONFIG_FILE="${CONFIG_DIR}/config.json"
if [[ ! -f "${CONFIG_FILE}" ]] && command -v jq >/dev/null 2>&1; then
    mkdir -p "${CONFIG_DIR}"
    chown -R 1000:1000 "${APP_DATA_DIR}/data/instances" || true
    UPDATED="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
    DD="${DEVICE_DOMAIN_NAME:-umbrel.local}"
    DH="${DEVICE_HOSTNAME:-umbrel}"
    PUB="http://${DD}:${_HOST_PORT}"
    jq -n \
        --arg updated "$UPDATED" \
        --arg pub "$PUB" \
        --arg dh "$DH" \
        --arg dd "$DD" \
        '{
      "$meta": {"version": 1, "updatedAt": $updated, "source": "onboard"},
      "database": {
        "mode": "embedded-postgres",
        "embeddedPostgresDataDir": "/paperclip/instances/default/db",
        "embeddedPostgresPort": 54329,
        "backup": {
          "enabled": true,
          "intervalMinutes": 60,
          "retentionDays": 30,
          "dir": "/paperclip/instances/default/data/backups"
        }
      },
      "logging": {"mode": "file", "logDir": "/paperclip/instances/default/logs"},
      "server": {
        "deploymentMode": "authenticated",
        "exposure": "private",
        "host": "0.0.0.0",
        "port": 3100,
        "allowedHostnames": ([$dd, $dh, "localhost", "127.0.0.1"] | map(ascii_downcase) | unique),
        "serveUi": true
      },
      "auth": {
        "baseUrlMode": "explicit",
        "publicBaseUrl": $pub,
        "disableSignUp": false
      },
      "storage": {
        "provider": "local_disk",
        "localDisk": {"baseDir": "/paperclip/instances/default/data/storage"},
        "s3": {
          "bucket": "paperclip",
          "region": "us-east-1",
          "prefix": "",
          "forcePathStyle": false
        }
      },
      "secrets": {
        "provider": "local_encrypted",
        "strictMode": false,
        "localEncrypted": {
          "keyFilePath": "/paperclip/instances/default/secrets/master.key"
        }
      }
    }' >"${CONFIG_FILE}.tmp"
    mv "${CONFIG_FILE}.tmp" "${CONFIG_FILE}"
    chown 1000:1000 "${CONFIG_FILE}" 2>/dev/null || true
fi
# Align saved config with the Umbrel-published port.
if [[ -f "${CONFIG_FILE}" ]] && command -v jq >/dev/null 2>&1; then
    _dd="${DEVICE_DOMAIN_NAME:-umbrel.local}"
    _want_pub="http://${_dd}:${_HOST_PORT}"
    jq --arg w "${_want_pub}" '.auth.publicBaseUrl = $w' "${CONFIG_FILE}" >"${CONFIG_FILE}.ptmp" \
        && mv "${CONFIG_FILE}.ptmp" "${CONFIG_FILE}"
    chown 1000:1000 "${CONFIG_FILE}" 2>/dev/null || true
fi

# Paperclip creates these paths at runtime as uid 1000. Ensure they already exist and
# are writable so a fresh install does not fail with EACCES on /paperclip/instances/default/logs.
mkdir -p \
    "${APP_DATA_DIR}/data/instances/default/logs" \
    "${APP_DATA_DIR}/data/instances/default/data/storage" \
    "${APP_DATA_DIR}/data/instances/default/data/backups" \
    "${APP_DATA_DIR}/data/instances/default/secrets"
chown -R 1000:1000 "${APP_DATA_DIR}/data/instances/default" || true
chmod 750 "${APP_DATA_DIR}/data/instances/default" || true

# Relative package bind mounts are unreliable here. Stage bootstrap assets into APP_DATA_DIR
# before compose up so the bootstrap sidecar always sees /bootstrap/server.mjs and index.html.
BOOTSTRAP_SRC="${PKG_ROOT}/bootstrap"
BOOTSTRAP_DST="${APP_DATA_DIR}/bootstrap"
mkdir -p "${BOOTSTRAP_DST}"
cp "${BOOTSTRAP_SRC}/index.html" "${BOOTSTRAP_DST}/index.html"
cp "${BOOTSTRAP_SRC}/server.mjs" "${BOOTSTRAP_DST}/server.mjs"
chown -R 1000:1000 "${BOOTSTRAP_DST}" || true
